# Sentiment Analysis Mode: 'generative' or 'light'
SENTIMENT_MODE=light

# Generative Model Configuration (OpenAI Standard API)
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=ollama
MODEL_NAME=llama3.2

# Light Model Configuration (Hugging Face)
# Default: lxyuan/distilbert-base-multilingual-cased-sentiments-student
LIGHT_MODEL_NAME=lxyuan/distilbert-base-multilingual-cased-sentiments-student

# If using OpenAI:
# SENTIMENT_ANALYSIS_ENABLED=true
SENTIMENT_MODE=generative
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=your_openai_api_key_here
# MODEL_NAME=gpt-4o
